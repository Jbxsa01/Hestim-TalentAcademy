rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read any file
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.name.matches('talents-covers/.*/.*');
      allow delete: if request.auth != null && request.resource.name.matches('talents-covers/.*/.*');
    }
  }
}
